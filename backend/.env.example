NODE_ENV=production
PORT=3001

# Supabase PostgreSQL (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require

# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-char-hex>
JWT_REFRESH_SECRET=<64-char-hex-diferente>

# Supabase (Settings → API)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=merge-agent

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Origens permitidas pelo CORS (separe com vírgula, sem espaço)
# Em prod: URL do Vercel. Em dev: http://localhost:5173
ALLOWED_ORIGINS=https://<seu-projeto>.vercel.app

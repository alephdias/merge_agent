# Em desenvolvimento o Vite proxy já aponta /api → localhost:3001 (vite.config.ts).
# Em produção (Vercel) o vercel.json faz o proxy reverso para o Railway.
# Só defina VITE_API_URL se precisar de um backend numa origem diferente sem proxy.
# VITE_API_URL=https://<seu-backend>.up.railway.app/api/v1
